# Home Assistant
HA_URL=http://localhost:8123
HA_TOKEN=your_long_lived_access_token_here

# Entity IDs — find in HA GUI → Developer Tools → States
HA_TV_ENTITY=media_player.lg_webos_smart_tv
HA_LIGHT_ENTITIES=light.living_room,light.bedroom

# Path to existing HA config directory on the host
HA_CONFIG_PATH=/home/hd/homeassistant/config

# CORS — leave empty when behind Nginx (same-origin)
ALLOWED_ORIGINS=
